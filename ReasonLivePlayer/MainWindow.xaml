<Window x:Class="ReasonLivePlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reasonable Live Player" Width="420" Height="520"
        Background="#1E1E1E" Foreground="White"
        Topmost="{Binding AlwaysOnTop}"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,8">
            <Button Content="{Binding PlayPauseLabel}" Command="{Binding PlayPauseCommand}"
                    Width="48" Height="36" FontSize="18" Style="{StaticResource TransportBtn}" Margin="2"
                    ToolTip="{Binding PlayPauseTooltip}"/>
            <Button Content="⏭" Command="{Binding SkipCommand}"
                    Width="48" Height="36" FontSize="18" Style="{StaticResource TransportBtn}" Margin="2"
                    ToolTip="Skip to next song"/>
            <Button Content="＋" Command="{Binding AddSongsCommand}"
                    Width="48" Height="36" FontSize="18" Style="{StaticResource TransportBtn}" Margin="2"
                    ToolTip="Add songs"/>
            <Button Content="💾" Command="{Binding SavePlaylistCommand}" ToolTip="Save playlist"
                    Width="36" Height="36" FontSize="14" Style="{StaticResource TransportBtn}" Margin="2"/>
            <Button Content="📂" Command="{Binding LoadPlaylistCommand}" ToolTip="Open playlist"
                    Width="36" Height="36" FontSize="14" Style="{StaticResource TransportBtn}" Margin="2"/>
            <Button Content="⚙" Command="{Binding OpenSettingsCommand}" ToolTip="Settings"
                    Width="36" Height="36" FontSize="14" Style="{StaticResource TransportBtn}" Margin="2"/>
            <Button Content="?" Command="{Binding OpenHelpCommand}" ToolTip="Help"
                    Width="36" Height="36" FontSize="14" Style="{StaticResource TransportBtn}" Margin="2"/>
            <!-- MIDI Connection Indicator -->
            <Ellipse Width="14" Height="14" Margin="8,0,0,0" VerticalAlignment="Center"
                     ToolTip="MIDI Connection">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="Red"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding MidiConnected}" Value="True">
                                <Setter Property="Fill" Value="LimeGreen"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <CheckBox Content="📌" IsChecked="{Binding AlwaysOnTop}" VerticalAlignment="Center"
                      Foreground="White" FontSize="16" Margin="8,0,0,0" ToolTip="Always on top"/>
        </StackPanel>

        <!-- Playlist (supports drag-reorder AND file drop from Explorer) -->
        <ListBox x:Name="PlaylistBox" Grid.Row="1" ItemsSource="{Binding Songs}" Background="#252525" BorderThickness="0"
                 AllowDrop="True" PreviewMouseLeftButtonDown="Playlist_PreviewMouseDown"
                 PreviewMouseMove="Playlist_PreviewMouseMove"
                 Drop="Playlist_Drop" DragOver="Playlist_DragOver" DragLeave="Playlist_DragLeave">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Now-playing / paused indicator (clickable to select next song) -->
                        <Button Grid.Column="0" Cursor="Hand"
                                Command="{Binding DataContext.SelectSongCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" Width="24" Height="24">
                                        <TextBlock FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource ActiveIndicator}">
                                                    <Binding Path="IsActive"/>
                                                    <Binding Path="DataContext.IsPlaylistActive"
                                                             RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                            <TextBlock.Foreground>
                                                <MultiBinding Converter="{StaticResource ActiveIndicatorColor}">
                                                    <Binding Path="IsActive"/>
                                                    <Binding Path="DataContext.IsPlaylistActive"
                                                             RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Drag handle -->
                        <TextBlock Grid.Column="1" Text="☰" FontSize="14" Foreground="#666"
                                   VerticalAlignment="Center" Cursor="SizeAll"/>
                        <!-- Song name -->
                        <TextBlock Grid.Column="2" Text="{Binding DisplayName}" Foreground="White"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="4,0"/>
                        <!-- Remove button -->
                        <Button Grid.Column="3" Content="✕" FontSize="10"
                                Command="{Binding DataContext.RemoveSongCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" Style="{StaticResource SmallBtn}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusText}" Foreground="#888" FontSize="11"
                   HorizontalAlignment="Center" Margin="0,4"/>
    </Grid>
</Window>
