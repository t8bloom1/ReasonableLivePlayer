<Window x:Class="ReasonLivePlayer.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="360" Height="360"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Text="MIDI Device:" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="DeviceCombo" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Text="Channel (1-16):" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ChannelCombo" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Text="Note (0-127):" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="NoteCombo" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="3" Text="Transition delay (s):" VerticalAlignment="Center" Margin="0,0,0,8"
                   ToolTip="Seconds to wait after closing a song before opening the next one (0-99)"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="DelayTextBox" Width="60" HorizontalAlignment="Left"
                 Margin="0,0,0,8" MaxLength="2"
                 ToolTip="0-99 seconds. Increase if the next song fails to open when another Reason file is in the background"/>

        <CheckBox Grid.Row="4" Grid.ColumnSpan="2" x:Name="LoadLastPlaylistCheck"
                  Content="Load last playlist on startup" Foreground="White" Margin="0,4,0,4"/>

        <CheckBox Grid.Row="5" Grid.ColumnSpan="2" x:Name="AlwaysOnTopCheck"
                  Content="Always on top" Foreground="White" Margin="0,4,0,4"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Save" Width="80" Height="28" Margin="0,0,8,0"
                    Click="Save_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Height="28"
                    Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
